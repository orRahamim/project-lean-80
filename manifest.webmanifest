<!doctype html><html lang="en" dir="ltr"><head><meta charset="UTF-8"/><meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover"/><meta name="theme-color" content="#c94f3d"/><meta name="apple-mobile-web-app-capable" content="yes"/><meta name="apple-mobile-web-app-status-bar-style" content="default"/><meta name="apple-mobile-web-app-title" content="Prep Recipe DB"/><link rel="manifest" href="./manifest.webmanifest"/><link rel="apple-touch-icon" href="./assets/icon-192.png"/><title>Prep Recipe DB</title><style>:root{--bg:#fff8f4;--card:#fff;--text:#261814;--muted:#7a625c;--line:#efd8d1;--primary:#c94f3d;--primary-2:#8f2d21;--chip:#f9e1db;--chip2:#f3efe9;--ok:#e4f5e7;--radius:18px;--shadow:0 10px 30px rgba(107,38,25,.10)}*{box-sizing:border-box}body{margin:0;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;background:linear-gradient(180deg,#fff8f4,#fff1eb);color:var(--text)}.app{max-width:1120px;margin:0 auto;padding:18px 16px 96px}.hero{background:linear-gradient(135deg,#c94f3d,#e07a5f);color:#fff;padding:20px;border-radius:24px;box-shadow:var(--shadow)}.hero h1{margin:0 0 8px;font-size:30px;line-height:1.04}.hero p{margin:0 0 10px;font-size:15px;opacity:.94;max-width:68ch}.hero .mini{display:flex;flex-wrap:wrap;gap:8px;margin-top:12px}.mini span{background:rgba(255,255,255,.16);padding:7px 10px;border-radius:999px;font-size:12px;font-weight:700}.toolbar{display:grid;grid-template-columns:1.2fr .9fr .9fr .9fr;gap:12px;margin:16px 0}.toolbar2{display:grid;grid-template-columns:repeat(4,1fr);gap:12px;margin:0 0 14px}.toolbar3{display:flex;gap:8px;flex-wrap:wrap;margin:0 0 18px}.pill{border:1px solid var(--line);background:#fff;border-radius:999px;padding:9px 12px;font-size:14px}.pill.active{background:var(--primary);color:#fff;border-color:var(--primary)}input,select{width:100%;padding:14px 16px;border:1px solid var(--line);border-radius:14px;background:#fff;font-size:16px}.stats{display:grid;grid-template-columns:repeat(4,1fr);gap:10px;margin:12px 0 18px}.stat{background:var(--card);border:1px solid var(--line);border-radius:16px;padding:14px;box-shadow:var(--shadow)}.stat b{display:block;font-size:22px;color:var(--primary-2)}.stat span{font-size:13px;color:var(--muted)}.grid{display:grid;gap:14px}.card{background:var(--card);border:1px solid var(--line);border-radius:var(--radius);padding:16px;box-shadow:var(--shadow)}.top{display:flex;justify-content:space-between;gap:12px;align-items:start}.chip{background:var(--chip);color:var(--primary-2);padding:7px 10px;border-radius:999px;font-size:12px;font-weight:700;white-space:nowrap}.chip.soft{background:var(--chip2);color:#5b4b47}.chip.ok{background:var(--ok);color:#24543a}h2{font-size:21px;margin:0 0 6px}.meta{color:var(--muted);font-size:14px;margin-bottom:12px}.macros{display:grid;grid-template-columns:repeat(4,1fr);gap:8px;margin:12px 0}.macro{background:#fff8f4;border-radius:12px;padding:10px;text-align:center}.macro strong{display:block;font-size:18px}.badges{display:flex;flex-wrap:wrap;gap:8px;margin:10px 0}.tag{font-size:12px;padding:6px 9px;border-radius:999px;background:#f4f1ee;color:#655954}.actions{display:flex;gap:8px;flex-wrap:wrap;margin-top:12px}.btn{border:none;border-radius:12px;padding:10px 12px;font-size:14px;font-weight:700;cursor:pointer}.btn.primary{background:var(--primary);color:#fff}.btn.ghost{background:#f4f1ee;color:#4f3f3a}.drawer-backdrop{position:fixed;inset:0;background:rgba(0,0,0,.42);opacity:0;pointer-events:none;transition:opacity .2s ease;z-index:19}.drawer-backdrop.open{opacity:1;pointer-events:auto}.drawer{position:fixed;inset:auto 0 0 0;background:#fff;border-top-left-radius:24px;border-top-right-radius:24px;box-shadow:0 -10px 40px rgba(0,0,0,.18);padding:18px 16px 24px;max-height:82vh;overflow:auto;transform:translateY(102%);transition:transform .25s ease;z-index:20}.drawer.open{transform:translateY(0)}.drawerHead{display:flex;justify-content:space-between;gap:12px;align-items:center;margin-bottom:12px}.drawerHead h3{margin:0;font-size:24px}.close{background:#f3efe9;border:none;border-radius:999px;padding:10px 12px;font-size:14px;font-weight:700}.drawerSection{margin:14px 0}.drawerSection h4{margin:0 0 8px;font-size:16px}.drawer ul,.drawer ol{padding-right:18px}.drawer li{margin:7px 0}.install{position:fixed;left:12px;right:12px;bottom:12px;background:#261814;color:#fff;padding:14px 16px;border-radius:18px;font-size:14px;box-shadow:var(--shadow)}@media (min-width:820px){.grid{grid-template-columns:repeat(2,1fr)}.hero h1{font-size:42px}}@media (max-width:819px){.toolbar,.toolbar2{grid-template-columns:1fr 1fr}.stats{grid-template-columns:1fr 1fr}}@media (max-width:560px){.toolbar,.toolbar2{grid-template-columns:1fr}.stats{grid-template-columns:1fr 1fr}.hero h1{font-size:34px}.macros{grid-template-columns:repeat(2,1fr)}}</style></head><body><div id="backdrop" class="drawer-backdrop"></div><main class="app"><section class="hero"><h1>Recipe DB</h1><p>High-protein meal prep database with fully normalized English tags, improved filtering, outside-tap-to-close drawers, and richer ingredients for every recipe.</p><div class="mini"><span id="miniRecipes">0 recipes</span><span>3 meals + dessert</span><span>Meal Prep</span><span>iPhone-friendly</span></div></section><section class="toolbar" aria-label="Search and filters"><input id="search" type="search" placeholder="Search by recipe, ingredient, or tag..."/><select id="category"><option value="all">All categories</option></select><select id="mealType"><option value="all">All meal types</option></select><select id="sort"><option value="default">Default sort</option><option value="protein">Highest protein</option><option value="caloriesAsc">Lowest calories</option><option value="caloriesDesc">Highest calories</option></select></section><section class="toolbar2"><select id="prep"><option value="all">All prep times</option><option value="15">Up to 15 min</option><option value="30">Up to 30 min</option></select><select id="protein"><option value="all">All protein levels</option><option value="25">25+ g protein</option><option value="35">35+ g protein</option><option value="45">45+ g protein</option></select><select id="storage"><option value="all">All storage</option><option value="mealprep">Meal Prep</option><option value="freezer">Freezer friendly</option></select><select id="servings"><option value="all">All servings</option><option value="1">1 serving</option><option value="2">2 servings</option><option value="4">4+ servings</option></select></section><section class="toolbar3" id="quickTags"></section><section class="stats"><article class="stat"><b id="countRecipes">0</b><span>Visible recipes</span></article><article class="stat"><b id="avgProtein">0g</b><span>Average protein</span></article><article class="stat"><b id="avgCalories">0</b><span>Average calories</span></article><article class="stat"><b id="countMealPrep">0</b><span>Meal-prep recipes</span></article></section><section id="recipes" class="grid"></section></main><aside id="drawer" class="drawer" aria-hidden="true"><div class="drawerHead"><h3 id="drawerTitle"></h3><button class="close" id="closeDrawer">Close</button></div><div id="drawerMeta" class="badges"></div><div class="macros" id="drawerMacros"></div><div class="drawerSection"><h4>Ingredients</h4><ul id="drawerIngredients"></ul></div><div class="drawerSection"><h4>Steps</h4><ol id="drawerSteps"></ol></div><div class="drawerSection"><h4>Tags</h4><div id="drawerTags" class="badges"></div></div></aside><script>const state={recipes:[],tag:'all'};const els={search:document.getElementById('search'),category:document.getElementById('category'),mealType:document.getElementById('mealType'),sort:document.getElementById('sort'),prep:document.getElementById('prep'),protein:document.getElementById('protein'),storage:document.getElementById('storage'),servings:document.getElementById('servings'),recipes:document.getElementById('recipes'),quickTags:document.getElementById('quickTags'),countRecipes:document.getElementById('countRecipes'),avgProtein:document.getElementById('avgProtein'),avgCalories:document.getElementById('avgCalories'),countMealPrep:document.getElementById('countMealPrep'),drawer:document.getElementById('drawer'),backdrop:document.getElementById('backdrop'),drawerTitle:document.getElementById('drawerTitle'),drawerMeta:document.getElementById('drawerMeta'),drawerMacros:document.getElementById('drawerMacros'),drawerIngredients:document.getElementById('drawerIngredients'),drawerSteps:document.getElementById('drawerSteps'),drawerTags:document.getElementById('drawerTags'),closeDrawer:document.getElementById('closeDrawer')};const quickTags=['high-protein','meal-prep','freezer','dessert','wrap','burger','pasta','breakfast','weekend'];function makeQuickTags(){els.quickTags.innerHTML=quickTags.map(t=>`<button class="pill ${state.tag===t?'active':''}" data-tag="${t}">${t}</button>`).join('')+`<button class="pill ${state.tag==='all'?'active':''}" data-tag="all">All</button>`;els.quickTags.querySelectorAll('[data-tag]').forEach(b=>b.addEventListener('click',()=>{state.tag=b.dataset.tag;makeQuickTags();render();}))}function uniq(arr){return [...new Set(arr)]}function fillSelect(sel, values, label){sel.innerHTML=`<option value="all">${label}</option>`+values.map(v=>`<option value="${v}">${v}</option>`).join('')}function avg(arr,key){if(!arr.length)return 0;return Math.round(arr.reduce((s,r)=>s+r.nutrition[key],0)/arr.length)}function card(r){return `<article class="card"><div class="top"><div><h2>${r.name}</h2><div class="meta">${r.servings} servings · ${r.times.prep_min} min prep · ${r.times.cook_min} min cook</div></div></div><div class="macros"><div class="macro"><strong>${r.nutrition.calories}</strong><span>Calories</span></div><div class="macro"><strong>${r.nutrition.protein_g}g</strong><span>Protein</span></div><div class="macro"><strong>${r.nutrition.carbs_g}g</strong><span>Carbs</span></div><div class="macro"><strong>${r.nutrition.fat_g}g</strong><span>Fat</span></div></div><div class="actions"><button class="btn primary" data-open="${r.id}">View recipe</button><button class="btn ghost" data-copy="${r.id}">Copy name</button></div><div class="badges">${r.tags.map(t=>`<span class="tag">${t}</span>`).join('')}</div></article>`}function getFiltered(){let items=[...state.recipes];const q=els.search.value.trim().toLowerCase();if(q)items=items.filter(r=>JSON.stringify(r).toLowerCase().includes(q));if(els.category.value!=='all')items=items.filter(r=>r.category===els.category.value);if(els.mealType.value!=='all')items=items.filter(r=>r.mealType===els.mealType.value);if(els.prep.value!=='all')items=items.filter(r=>r.times.prep_min<=Number(els.prep.value));if(els.protein.value!=='all')items=items.filter(r=>r.nutrition.protein_g>=Number(els.protein.value));if(els.storage.value==='mealprep')items=items.filter(r=>r.storage.meal_prep);if(els.storage.value==='freezer')items=items.filter(r=>r.storage.freezer_friendly);if(els.servings.value==='1')items=items.filter(r=>r.servings===1);if(els.servings.value==='2')items=items.filter(r=>r.servings===2);if(els.servings.value==='4')items=items.filter(r=>r.servings>=4);if(state.tag!=='all')items=items.filter(r=>r.tags.includes(state.tag));if(els.sort.value==='protein')items.sort((a,b)=>b.nutrition.protein_g-a.nutrition.protein_g);if(els.sort.value==='caloriesAsc')items.sort((a,b)=>a.nutrition.calories-b.nutrition.calories);if(els.sort.value==='caloriesDesc')items.sort((a,b)=>b.nutrition.calories-a.nutrition.calories);return items}function closeRecipe(){els.drawer.classList.remove('open');els.backdrop.classList.remove('open');els.drawer.setAttribute('aria-hidden','true')}function openRecipe(id){const r=state.recipes.find(x=>x.id===id);if(!r)return;els.drawerTitle.textContent=r.name;els.drawerMeta.innerHTML=`<span class="chip">${r.category}</span><span class="chip soft">${r.mealType}</span><span class="chip soft">${r.servings} servings</span><span class="chip soft">${r.times.prep_min} min prep</span><span class="chip soft">${r.times.cook_min} min cook</span>${r.storage.meal_prep?'<span class="chip ok">Meal Prep</span>':''}${r.storage.freezer_friendly?'<span class="chip ok">Freezer</span>':''}`;els.drawerMacros.innerHTML=`<div class="macro"><strong>${r.nutrition.calories}</strong><span>Calories</span></div><div class="macro"><strong>${r.nutrition.protein_g}g</strong><span>Protein</span></div><div class="macro"><strong>${r.nutrition.carbs_g}g</strong><span>Carbs</span></div><div class="macro"><strong>${r.nutrition.fat_g}g</strong><span>Fat</span></div>`;els.drawerIngredients.innerHTML=r.ingredients.map(i=>`<li>${i}</li>`).join('');els.drawerSteps.innerHTML=r.steps.map(i=>`<li>${i}</li>`).join('');els.drawerTags.innerHTML=r.tags.map(t=>`<span class="tag">${t}</span>`).join('');els.drawer.classList.add('open');els.backdrop.classList.add('open');els.drawer.setAttribute('aria-hidden','false')}els.closeDrawer.addEventListener('click',closeRecipe);els.backdrop.addEventListener('click',closeRecipe);async function init(){const res=await fetch('./recipes-v2.json');const data=await res.json();state.recipes=data;document.getElementById('miniRecipes').textContent=`${data.length} recipes`;fillSelect(els.category, uniq(data.map(r=>r.category)), 'All categories');fillSelect(els.mealType, uniq(data.map(r=>r.mealType)), 'All meal types');[els.search,els.category,els.mealType,els.sort,els.prep,els.protein,els.storage,els.servings].forEach(el=>el.addEventListener('input',render));[els.category,els.mealType,els.sort,els.prep,els.protein,els.storage,els.servings].forEach(el=>el.addEventListener('change',render));makeQuickTags();render();if('serviceWorker' in navigator){navigator.serviceWorker.register('./service-worker.js').catch(()=>{})}}function render(){const items=getFiltered();els.recipes.innerHTML=items.map(card).join('')||'<article class="card"><h2>No recipes found</h2><p>Try a different filter or clear the tag chips.</p></article>';els.countRecipes.textContent=items.length;els.avgProtein.textContent=avg(items,'protein_g')+'g';els.avgCalories.textContent=avg(items,'calories');els.countMealPrep.textContent=items.filter(r=>r.storage.meal_prep).length;els.recipes.querySelectorAll('[data-open]').forEach(b=>b.addEventListener('click',()=>openRecipe(b.dataset.open)));els.recipes.querySelectorAll('[data-copy]').forEach(b=>b.addEventListener('click',()=>{const r=state.recipes.find(x=>x.id===b.dataset.copy);navigator.clipboard?.writeText(r.name);b.textContent='Copied';setTimeout(()=>b.textContent='Copy name',1200)}))}init();</script></body></html>